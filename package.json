{
  "name": "unveil",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:fresh": "rm -rf .next && next dev -p 3000",
    "build": "NEXT_DIST_DIR=.next-build next build",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "server": "API_PORT=3002 tsx watch server/index.ts",
    "seed": "tsx server/seed.ts",
    "dev:all": "concurrently \"npm run dev:fresh\" \"npm run server\""
  },
  "dependencies": {
    "@sentry/nextjs": "^10.55.0",
    "@sentry/node": "^10.55.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^12.40.0",
    "mongoose": "^8.5.1",
    "next": "^14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.39",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.16.2",
    "typescript": "^5"
  }
}
